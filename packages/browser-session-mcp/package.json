{
  "name": "browser-session-mcp",
  "version": "0.1.0",
  "description": "MCP server giving each caller its own isolated browser session (Puppeteer BrowserContext), against a shared persistent Chrome.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "browser-session-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "devtools-protocol": "*",
    "puppeteer-core": "^24.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
}
