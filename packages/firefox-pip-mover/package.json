{
  "name": "firefox-pip-mover",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Firefox Picture-in-Picture mover, bundled into the autoconfig (firefox.cfg)",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=iife --platform=neutral --target=es2020 --legal-comments=none --outfile=pip-mover.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
