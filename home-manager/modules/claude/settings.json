{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.nu"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/format-and-lint.nu"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.nu",
    "padding": 0
  },
  "enabledPlugins": {
    "mgrep@Mixedbread-Grep": false,
    "vtsls@claude-code-lsps": false,
    "vscode-langservers@claude-code-lsps": false,
    "typescript-lsp@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "dts@outsmartly-plugins": false,
    "pts@outsmartly-plugins": false
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "autoMemory": {
    "enabled": true,
    "scope": "user"
  },
  "autoDream": {
    "enabled": true,
    "intervalHours": 24
  },
  "editorMode": "vim"
}
