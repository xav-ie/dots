{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "GitHub",
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "context-used"
      ]
    },
    "terminalBackgroundPollingInterval": 600,
    "autoThemeSwitching": false,
    "inlineThinkingMode": "full",
    "escapePastedAtSymbols": true,
    "useAlternateBuffer": true,
    "showSpinner": false
  },
  "general": {
    "vimMode": true,
    "preferredEditor": "neovim",
    "enableNotifications": true
  },
  "experimental": {
    "useOSC52Paste": true,
    "useOSC52Copy": true,
    "modelSteering": true,
    "directWebFetch": true,
    "memoryManager": true,
    "contextManagement": true,
    "topicUpdateNarration": false
  },
  "mcpServers": {
    "executor": {
      "httpUrl": "https://executor.lalala.casa/mcp",
      "trust": true
    }
  }
}
